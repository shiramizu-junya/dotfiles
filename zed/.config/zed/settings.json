// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "cli_default_open_behavior": "existing_window",
    "project_panel": {
        "dock": "left",
    },
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": [],
        "commit_message_model": {
            "provider": "copilot_chat",
            "model": "gpt-4o",
        },
        "commit_message_instructions": "Conventional Commits 形式 (feat/fix/refactor/test/docs/build/chore) で、日本語で簡潔に書くこと。1行目は <type>: <要約> とし、72文字以内。必要なら空行のあと本文を続ける。",
    },
    "git_panel": {
        "dock": "left",
    },
    "vim_mode": true,
    "vim": {
        // y/p をOSのクリップボードに連動(別アプリとコピペできる)
        "use_system_clipboard": "on_yank",
        // f/t 検索を大文字小文字あいまいに(小文字入力なら両方ヒット)
        "use_smartcase_find": true,
        // ノーマル=相対行 / インサート=絶対行 に自動で切り替え
        "toggle_relative_line_numbers": true,
    },
    "terminal": {
        "font_size": 16.0,
        "font_family": "Hack Nerd Font",
        "line_height": {
            "custom": 1.2,
        },
        "cursor_shape": "bar",
        "blinking": "on",
        "max_scroll_history_lines": 10000,
        "copy_on_select": true,
        "working_directory": "current_project_directory",
        "env": {
            "EDITOR": "zed --wait",
        },
    },
    "base_keymap": "VSCode",
    "preview_tabs": {
        "enabled": false,
        "enable_preview_from_file_finder": false,
    },
    "tabs": {
        "git_status": true,
        "file_icons": true,
    },
    "relative_line_numbers": "enabled",
    "gutter": {
        "line_numbers": true,
    },
    "minimap": {
        "show": "always",
    },
    "rounded_selection": false,
    "current_line_highlight": "all",
    "cursor_shape": "bar",
    "cursor_blink": false,
    "max_tabs": 10,
    "use_system_path_prompts": false,
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "colorize_brackets": true,
    "auto_indent_on_paste": true,
    "use_on_type_format": false,
    "show_whitespaces": "all",
    "show_edit_predictions": true,
    "ensure_final_newline_on_save": true,
    "format_on_save": "on",
    "remove_trailing_whitespace_on_save": true,
    "wrap_guides": [80, 100],
    "tab_size": 4,
    "agent_servers": {
        "github-copilot-cli": {
            "type": "registry",
        },
        "claude-acp": {
            "type": "registry",
        },
    },
    "icon_theme": {
        "mode": "system",
        "light": "Catppuccin Frappé",
        "dark": "Zed (Default)",
    },
    "ui_font_size": 15.0,
    "buffer_font_size": 18.0,
    "theme": {
        "mode": "dark",
        "light": "One Dark",
        "dark": "Catppuccin Macchiato - No Italics",
    },
}
